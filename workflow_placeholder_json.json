{
  "name": "Morning Chaos Briefing",
  "notes": "Import this into N8N on Pulsar0100. Wire nodes in order. Replace all placeholder values.",
  "nodes": [
    {
      "name": "Trigger at 6AM",
      "type": "n8n-nodes-base.cron",
      "parameters": {
        "cronExpression": "0 6 * * *"
      }
    },
    {
      "name": "Get Weather",
      "type": "n8n-nodes-base.executeCommand",
      "parameters": {
        "command": "python3 /path/to/morning-chaos-briefing/scripts/get_weather.py"
      }
    },
    {
      "name": "Get Chaos Line",
      "type": "n8n-nodes-base.executeCommand",
      "parameters": {
        "command": "python3 /path/to/morning-chaos-briefing/scripts/chaos_line.py"
      }
    },
    {
      "name": "Build Message",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "notes": "Combine weather, chaos line, dispatch status, and finance data into final message string"
      }
    },
    {
      "name": "Send to Discord",
      "type": "n8n-nodes-base.discord",
      "parameters": {
        "webhookUrl": "YOUR_DISCORD_WEBHOOK_URL_HERE",
        "message": "{{$node['Build Message'].data.message}}"
      }
    }
  ]
}
